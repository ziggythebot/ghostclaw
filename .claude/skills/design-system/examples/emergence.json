{
  "name": "Emergence London 2026",
  "description": "Tech Week event aggregator - bold, brutalist, network-driven aesthetic",
  "fonts": {
    "heading": "Epilogue",
    "body": "DM Sans",
    "mono": "JetBrains Mono"
  },
  "colors": {
    "primary": "#00D27F",
    "secondary": "#FFD600",
    "ink": "#251720",
    "background": "#FFFFFF",
    "node-primary": "#00D27F",
    "node-secondary": "#FFD600",
    "node-tertiary": "#FF5733",
    "border": "#251720"
  },
  "spacing": {
    "base": "8px",
    "small": "4px",
    "medium": "16px",
    "large": "24px",
    "xlarge": "32px",
    "section": "48px"
  },
  "typography": {
    "h1": "48px",
    "h2": "36px",
    "h3": "24px",
    "h4": "20px",
    "body": "16px",
    "small": "14px",
    "mono": "14px"
  },
  "borders": {
    "default": "3px",
    "radius": "0px"
  },
  "rules": [
    "Always use 3px borders",
    "No rounded corners except circles (borderRadius: 50%)",
    "No gradients",
    "Network nodes use primary (#00D27F), secondary (#FFD600), or tertiary (#FF5733) colors",
    "Buttons have 3px solid borders with ink (#251720)",
    "Maximum border-radius is 50% (circles only)",
    "Use mono font (JetBrains Mono) for dates, times, metadata",
    "Maintain brutalist aesthetic - sharp edges, bold borders",
    "Background is always white (#FFFFFF)",
    "Ink (#251720) is for text and borders only"
  ],
  "components": {
    "button": {
      "padding": "12px 24px",
      "border": "3px solid #251720",
      "borderRadius": "0px",
      "fontFamily": "DM Sans",
      "fontSize": "16px",
      "fontWeight": "600"
    },
    "card": {
      "padding": "24px",
      "border": "3px solid #251720",
      "borderRadius": "0px",
      "background": "#FFFFFF"
    },
    "section": {
      "paddingTop": "48px",
      "paddingBottom": "48px"
    }
  },
  "examples": {
    "correct": [
      "border: 3px solid #251720",
      "borderRadius: 50% (for circles)",
      "fontFamily: 'Epilogue' (headings)",
      "color: #00D27F (primary)",
      "padding: 24px (card)"
    ],
    "incorrect": [
      "border: 2px solid #000 (wrong border width)",
      "borderRadius: 8px (no rounded corners allowed)",
      "background: linear-gradient(...) (no gradients)",
      "color: #FF0000 (not in palette)",
      "padding: 15px (not in spacing system)"
    ]
  }
}
