{
  "name": "Velocity",
  "description": "AI-native product development tool - clean, modern, professional",
  "fonts": {
    "heading": "Inter",
    "body": "Inter",
    "mono": "Fira Code"
  },
  "colors": {
    "primary": "#667eea",
    "secondary": "#764ba2",
    "ink": "#1a202c",
    "text-secondary": "#4a5568",
    "background": "#ffffff",
    "surface": "#f7fafc",
    "border": "#e2e8f0",
    "success": "#48bb78",
    "warning": "#ed8936",
    "error": "#f56565"
  },
  "spacing": {
    "base": "8px",
    "xs": "4px",
    "sm": "8px",
    "md": "16px",
    "lg": "24px",
    "xl": "32px",
    "2xl": "48px",
    "3xl": "64px"
  },
  "typography": {
    "h1": "56px",
    "h2": "40px",
    "h3": "32px",
    "h4": "24px",
    "h5": "20px",
    "body": "16px",
    "small": "14px",
    "xs": "12px"
  },
  "borders": {
    "default": "1px",
    "thick": "2px",
    "radius-sm": "4px",
    "radius-md": "8px",
    "radius-lg": "12px",
    "radius-full": "9999px"
  },
  "shadows": {
    "sm": "0 1px 2px 0 rgba(0, 0, 0, 0.05)",
    "md": "0 4px 6px -1px rgba(0, 0, 0, 0.1)",
    "lg": "0 10px 15px -3px rgba(0, 0, 0, 0.1)",
    "xl": "0 20px 25px -5px rgba(0, 0, 0, 0.1)"
  },
  "rules": [
    "Use subtle shadows for depth (not heavy drop shadows)",
    "Rounded corners are allowed (4px, 8px, 12px)",
    "Gradients allowed for CTAs and hero sections only",
    "Primary gradient: linear-gradient(135deg, #667eea 0%, #764ba2 100%)",
    "Use Inter for all text (heading and body)",
    "Code blocks use Fira Code mono font",
    "Maintain professional, clean aesthetic",
    "Buttons can have gradients or solid colors",
    "Cards have subtle shadows (shadow-md)",
    "Section spacing is consistent (48px or 64px)"
  ],
  "components": {
    "button-primary": {
      "background": "linear-gradient(135deg, #667eea 0%, #764ba2 100%)",
      "color": "#ffffff",
      "padding": "12px 24px",
      "borderRadius": "8px",
      "border": "none",
      "fontWeight": "600",
      "fontSize": "16px"
    },
    "button-secondary": {
      "background": "#ffffff",
      "color": "#667eea",
      "padding": "12px 24px",
      "borderRadius": "8px",
      "border": "2px solid #667eea",
      "fontWeight": "600",
      "fontSize": "16px"
    },
    "card": {
      "padding": "24px",
      "background": "#ffffff",
      "borderRadius": "12px",
      "border": "1px solid #e2e8f0",
      "boxShadow": "0 4px 6px -1px rgba(0, 0, 0, 0.1)"
    },
    "input": {
      "padding": "12px 16px",
      "border": "1px solid #e2e8f0",
      "borderRadius": "8px",
      "fontSize": "16px",
      "fontFamily": "Inter"
    }
  },
  "examples": {
    "correct": [
      "borderRadius: 8px (allowed)",
      "background: linear-gradient(135deg, #667eea 0%, #764ba2 100%) (primary gradient)",
      "boxShadow: 0 4px 6px -1px rgba(0, 0, 0, 0.1) (card shadow)",
      "fontFamily: 'Inter'",
      "padding: 24px (card)"
    ],
    "incorrect": [
      "borderRadius: 0px (use 8px for cards/buttons)",
      "border: 5px solid (use 1px or 2px)",
      "fontFamily: 'Arial' (use Inter)",
      "boxShadow: 0 0 50px rgba(0,0,0,0.8) (too heavy)",
      "background: linear-gradient(...) on text (gradients for CTAs/hero only)"
    ]
  }
}
